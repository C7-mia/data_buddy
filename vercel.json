{
  "buildCommand": "pip install -r requirements.txt",
  "functions": {
    "api/analyze.py": {
      "runtime": "python3.9"
    }
  },
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/templates/index.html"
    }
  ]
}
